# osu! OAuth app credentials — https://osu.ppy.sh/home/account/edit (OAuth section)
OSU_CLIENT_ID=
OSU_CLIENT_SECRET=
OSU_REDIRECT_URI=http://localhost:3000/api/auth/callback

# optional AI coach — any OpenAI-compatible chat endpoint. leave empty to skip.
# free options: Groq (console.groq.com), Gemini compat mode (aistudio.google.com),
# OpenRouter free models e.g. x-ai/grok-4-fast:free (openrouter.ai)
COACH_API_KEY=
COACH_API_URL=https://api.groq.com/openai/v1/chat/completions
COACH_MODEL=llama-3.3-70b-versatile
